# DropShipFlow 后端环境变量模板 —— 复制为 .env 并按需修改
# 生产环境务必：DEBUG=false 且设置强随机 SECRET_KEY / CREDENTIAL_ENCRYPTION_KEY

# 调试开关。生产必须为 false（false 时若 SECRET_KEY 仍为默认值将拒绝启动）
DEBUG=true

# JWT 签名密钥。生成：python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-strong-random-value

# 凭据加密密钥（Fernet）。生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 缺省时会从 SECRET_KEY 派生；生产建议显式设置并独立保管
CREDENTIAL_ENCRYPTION_KEY=

# 数据库与缓存
DATABASE_URL=sqlite+aiosqlite:///./dropshipflow.db
REDIS_URL=redis://localhost:6379/0

# 图片存储：local | s3
STORAGE_BACKEND=local
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL_PREFIX=

# ComfyUI
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_TIMEOUT=300
